# Snowflake connection
SNOWFLAKE_USER=your_user@company.com
SNOWFLAKE_ACCOUNT=your_account.region
SNOWFLAKE_AUTHENTICATOR=externalbrowser   # or omit for password auth
# SNOWFLAKE_PASSWORD=your_password        # only needed if not using externalbrowser

# Optional — short aliases (SNOWFLAKE_WH / SNOWFLAKE_DB) also work
SNOWFLAKE_ROLE=your_role
SNOWFLAKE_WAREHOUSE=your_warehouse
SNOWFLAKE_DATABASE=your_database
SNOWFLAKE_SCHEMA=your_schema

# Safety
SNOWFLAKE_READ_ONLY=true
